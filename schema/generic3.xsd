			<xs:extension base="rail3:TimePeriodBase">
				<xs:sequence/>
				<xs:attribute name="from" use="optional" type="xs:dateTime"/>
				<xs:attribute name="to" use="optional" type="xs:dateTime"/>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="CalendarTimePeriodWithBitmask">
