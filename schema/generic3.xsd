	<xs:complexType name="WeekPatterns">
		<xs:sequence>
			<xs:element name="weekPattern" type="rail3:WeekPattern" minOccurs="1" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>A weekpattern describes the general pattern of operating days between a startDate and an endDate that is the base of the enclosing bitmask.&#xD;
It is important to note that the weekPatterns provided here are not the leading information in terms validity. They are provided only in order to explain how the enclosing bitmask was constructed.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
